engine-strict=true

# pnpm v10 blocks dependency lifecycle scripts by default unless explicitly allowed.
# - supabase: needs its install script to download the CLI binary so `pnpm exec supabase` works.
# - @swc/core: native compiler used by `@vitejs/plugin-react-swc`; needs its postinstall to fetch the platform binary.
onlyBuiltDependencies[]=supabase
onlyBuiltDependencies[]=@swc/core
